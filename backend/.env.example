# OpenAI API Key for GPT-4o analysis
OPENAI_API_KEY=sk-...

# Qdrant vector database connection (Cloud-hosted)
QDRANT_URL=https://your-instance.cloud.qdrant.io:6333
QDRANT_API_KEY=your-api-key-here
QDRANT_COLLECTION=defihacklabs

# Blockchain RPC endpoint (Initia, Avalanche, etc.)
RPC_URL=https://jsonrpc-evm-1.anvil.asia-southeast.initia.xyz
# or for Avalanche: https://api.avax.network/ext/bc/C/rpc

# RAXC Vault contract address (deployed RaxcCreditVault)
VAULT_ADDRESS=0x4e91C13158D3E0a8F8fBb7cce91712c6F9886690

# Operator wallet private key (has OPERATOR_ROLE in the vault contract)
# WARNING: Keep this secure! Never commit to git!
OPERATOR_PRIVATE_KEY=0x1999a8e0fd49ee0051300a376d91b70438f1eeeb25fd761ba728a8b8a8088291
